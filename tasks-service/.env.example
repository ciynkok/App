# Task Service Environment Configuration

# Application
APP_NAME=Task Service
APP_VERSION=1.0.0
DEBUG=False

# Server
HOST=0.0.0.0
PORT=3002

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taskdb

# Auth Service
AUTH_SERVICE_URL=http://auth-service:3001
AUTH_SERVICE_VERIFY_ENDPOINT=/api/auth/verify

# Real-time Service
REALTIME_SERVICE_URL=http://realtime-service:3003
REALTIME_WEBHOOK_ENDPOINT=/internal/events

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Scheduler
SCHEDULER_ENABLED=True
