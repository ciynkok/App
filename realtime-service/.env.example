# Realtime Service Environment Variables (Example)
# Copy this file to .env and update values as needed

# Redis
REDIS_URL=redis://redis:6379

# JWT (должен совпадать с JWT_SECRET_KEY в auth-service и task-service)
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ALGORITHM=HS256

# Server
NODE_ENV=development
PORT=3003

# Настройки чата
CHAT_HISTORY_TTL=86400           # 24 часа
CHAT_HISTORY_MAX_MESSAGES=100    # Максимум сообщений в истории

# Настройки блокировки
TASK_LOCK_TTL=30                 # 30 секунд

# Inter-service API Key
SERVICE_API_KEY=your-inter-service-api-key-min-32-chars

# CORS
FRONTEND_URL=http://localhost:3000
