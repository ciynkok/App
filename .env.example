# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_DB=auth_db  # основная БД для auth-service

# ─── Database URLs для сервисов ───────────────────────
# Auth Service (своя БД)
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:secret@postgres:5432/auth_db

# Task Service (своя БД)
TASK_DATABASE_URL=postgresql+asyncpg://postgres:secret@postgres:5432/task_db

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT Secrets (используются только auth-service) ──────
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=1h

REFRESH_TOKEN_SECRET=your-refresh-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Inter-service API Key ───────────────────────────────
SERVICE_API_KEY=your-inter-service-api-key-min-32-chars

# ─── OAuth2 - Google ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost/auth/google/callback

# ─── OAuth2 - GitHub ─────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost/auth/github/callback

# ─── Task Service ─────────────────────────────────────
REALTIME_SERVICE_URL=http://realtime:3003

# ─── Real-time Service ────────────────────────────────
AUTH_SERVICE_URL=http://auth:3001

# ─── Frontend ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# ─── Общие ────────────────────────────────────────────
NODE_ENV=development
