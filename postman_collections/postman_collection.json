      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\",\n  \"name\": \"{{user_name}}\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/register",
              "host": ["{{auth_base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Регистрация нового пользователя"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', jsonData.accessToken);",
                  "    pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
                  "    pm.collectionVariables.set('user_id', jsonData.user.id);",
                  "    pm.collectionVariables.set('user_email', jsonData.user.email);",
                  "    console.log('Tokens saved to collection variables');",
                  "}"
                ]
